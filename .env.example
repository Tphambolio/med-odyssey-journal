# Supabase Configuration
# Get these from your Supabase project settings (Settings > API)
# These must also be set in the Vercel dashboard under Settings > Environment Variables
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# OAuth Providers (configured in Supabase dashboard, not as env vars)
# ─────────────────────────────────────────────────────────────────
# Google OAuth:
#   1. Create credentials at https://console.cloud.google.com/apis/credentials
#   2. Set authorized redirect URI to: https://<your-supabase-project>.supabase.co/auth/v1/callback
#   3. Add Client ID and Client Secret in Supabase Dashboard > Auth > Providers > Google
#
# Facebook OAuth:
#   1. Create an app at https://developers.facebook.com/apps/
#   2. Set Valid OAuth Redirect URI to: https://<your-supabase-project>.supabase.co/auth/v1/callback
#   3. Add App ID and App Secret in Supabase Dashboard > Auth > Providers > Facebook

# Vercel Deployment Notes
# ─────────────────────────────────────────────────────────────────
# In the Vercel dashboard (Settings > Environment Variables), set:
#   - VITE_SUPABASE_URL       → your Supabase project URL
#   - VITE_SUPABASE_ANON_KEY  → your Supabase anon/public key
#
# The vercel.json references these as @vite_supabase_url and @vite_supabase_anon_key
# (Vercel Secrets). Create them with:
#   vercel secrets add vite_supabase_url "https://xxx.supabase.co"
#   vercel secrets add vite_supabase_anon_key "eyJ..."
